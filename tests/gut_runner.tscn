; This scene runs all GUT tests headless. It requires the GUT v9+ addon to be
; installed at addons/gut/ before it will load without errors in the editor.
; Install via: Godot editor → AssetLib → search "Gut" → Install, then enable
; the plugin under Project → Project Settings → Plugins → GUT.
;
; Run all tests (CI / headless):
;   godot --path . --headless -s addons/gut/gut_cmdln.gd -gdir=res://tests/unit -ginclude_subdirs -gprefix=test_ -gsuffix=.gd -gexit
;
; Run a single suite:
;   godot --path . --headless -s addons/gut/gut_cmdln.gd -gtest=res://tests/unit/test_grid.gd -gexit

[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/gut/gut.gd" id="1"]

[node name="GutRunner" type="Node"]
script = ExtResource("1")
dirs = Array[String](["res://tests/unit/"])
prefix = "test_"
suffix = ".gd"
include_subdirs = true
should_exit = true
should_exit_on_success = false
log_level = 1
run_on_load = true
